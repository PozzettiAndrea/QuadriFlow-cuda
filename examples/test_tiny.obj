# Two triangles sharing edge v1-v2
# Forms a "bowtie" quad: v3-v1-v4 on top, v3-v2-v4 on bottom (but as triangles)
#
#   v1 -------- v3
#   |  \    f0  |
#   |   \       |
#   |    \      |
#   |     \     |
#   | f1   \    |
#   |       \   |
#   v4 -------- v2
#
v 0.0 0.0 0.0
v 1.0 1.0 0.0
v 1.0 0.0 0.0
v 0.0 1.0 0.0
f 1 2 3
f 1 4 2
